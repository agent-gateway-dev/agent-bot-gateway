{
  "name": "codex-discord-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord bridge for Codex app-server",
  "packageManager": "bun@1.2.5",
  "bin": {
    "dc-bridge": "bin/dc-bridge"
  },
  "scripts": {
    "start": "bun run src/index.js",
    "start:ts": "bun run src/app/main.ts",
    "cli": "bun run src/cli/index.ts",
    "lint": "eslint \"src/{app,attachments,channels,cli,codex,config,render,types}/**/*.{js,ts}\" \"test/**/*.ts\"",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "scan:secrets": "bash ./scripts/scan-secrets.sh"
  },
  "dependencies": {
    "discord.js": "^14.20.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  }
}
